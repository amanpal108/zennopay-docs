{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Zennopay",
  "theme": "venus",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/images/favicon.svg",
  "background": {
    "style": "windows"
  },
  "colors": {
    "primary": "#6560FF",
    "light": "#c2c1ff",
    "dark": "#091422",
    "background": {
      "light": "#ffffff",
      "dark": "#091422"
    },
    "anchors": {
      "from": "#c2c1ff",
      "to": "#6560FF"
    }
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "font": {
    "headings": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Inter"
    }
  },
  "topbarLinks": [
    {
      "name": "Contact",
      "url": "mailto:support@zennopay.com"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://dashboard.zennopay.com",
    "style": "pill"
  },
  "anchors": [
    {
      "name": "API Reference",
      "icon": "code",
      "url": "api-reference"
    },
    {
      "name": "SDKs",
      "icon": "mobile",
      "url": "sdks"
    },
    {
      "name": "Changelog",
      "icon": "list",
      "url": "changelog"
    }
  ],
  "navigation": [
    {
      "group": "Get started",
      "pages": [
        "introduction",
        "quickstart",
        "authentication"
      ]
    },
    {
      "group": "API Reference",
      "pages": [
        "api-reference/overview",
        "api-reference/environments",
        "api-reference/playground",
        {
          "group": "Payment Intents",
          "pages": [
            "api-reference/payment-intents/create",
            "api-reference/payment-intents/get"
          ]
        },
        "api-reference/webhooks",
        "api-reference/jwt-inspector"
      ]
    },
    {
      "group": "SDKs",
      "pages": [
        "sdks/ios",
        "sdks/android"
      ]
    },
    {
      "group": "Concepts",
      "pages": [
        "concepts/funds-flow",
        "concepts/corridors",
        "concepts/settlement"
      ]
    },
    {
      "group": "Reference",
      "pages": [
        "changelog"
      ]
    }
  ],
  "footerSocials": {
    "website": "https://zennopay.com"
  }
}
